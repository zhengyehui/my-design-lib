{
  "name": "my-design-lib",
  "version": "1.0.0",
  "description": "AI-native design system — 为 AI 编程助手优化的前端组件库",
  "cdn_base": "http://101.37.166.208:11930",
  "mcp_server": {
    "command": "python3",
    "args": ["scripts/mcp_server.py"],
    "description": "MCP Server，让 AI 编程工具直接调用组件库"
  },
  "llms_txt": "/llms.txt",
  "tokens": {
    "css": "/tokens/tokens.css",
    "json": "/tokens/tokens.json"
  },
  "components": [
    {
      "name": "button",
      "description": "按钮组件，支持4种变体和3种尺寸，带图标和波纹动效",
      "variants": ["primary", "secondary", "ghost", "danger"],
      "sizes": ["sm", "md", "lg"],
      "tags": ["form", "action", "interactive"],
      "css_path": "/components/button/button.css",
      "html_path": "/components/button/button.html",
      "demo_path": "/docs/components/button"
    },
    {
      "name": "card",
      "description": "内容卡片，支持图片、标签、标题、描述、底部操作区",
      "variants": ["default", "flat", "glass", "gradient"],
      "tags": ["layout", "content", "container"],
      "css_path": "/components/card/card.css",
      "html_path": "/components/card/card.html",
      "demo_path": "/docs/components/card"
    },
    {
      "name": "hero",
      "description": "落地页首屏 Hero 区域，带光晕效果、渐变文字、网格背景",
      "variants": ["default", "compact"],
      "tags": ["layout", "landing", "header"],
      "css_path": "/components/hero/hero.css",
      "html_path": "/components/hero/hero.html",
      "demo_path": "/docs/components/hero"
    },
    {
      "name": "input",
      "description": "表单输入框，支持标签、图标、错误/成功状态、文本域",
      "variants": ["default", "error", "success"],
      "tags": ["form", "input", "interactive"],
      "css_path": "/components/input/input.css",
      "html_path": "/components/input/input.html",
      "demo_path": "/docs/components/input"
    },
    {
      "name": "badge",
      "description": "标签/徽章组件，支持多种颜色、空心变体、角标模式",
      "variants": ["primary", "secondary", "success", "warning", "danger", "outline"],
      "sizes": ["sm", "md", "lg"],
      "tags": ["display", "status", "label"],
      "css_path": "/components/badge/badge.css",
      "html_path": "/components/badge/badge.html",
      "demo_path": "/docs/components/badge"
    },
    {
      "name": "modal",
      "description": "模态对话框，带遮罩模糊、弹入动画、头部/内容/底部三段式",
      "variants": ["default", "sm", "lg"],
      "tags": ["overlay", "dialog", "interactive"],
      "css_path": "/components/modal/modal.css",
      "html_path": "/components/modal/modal.html",
      "demo_path": "/docs/components/modal"
    },
    {
      "name": "navbar",
      "description": "响应式导航栏，支持透明/毛玻璃变体，移动端汉堡菜单",
      "variants": ["default", "transparent", "glass"],
      "tags": ["layout", "navigation", "header"],
      "html_path": "/components/navbar/navbar.html",
      "demo_path": "/docs/components/navbar"
    },
    {
      "name": "footer",
      "description": "页脚组件，多列链接布局，支持简约和深色变体",
      "variants": ["default", "minimal", "dark"],
      "tags": ["layout", "navigation", "footer"],
      "html_path": "/components/footer/footer.html",
      "demo_path": "/docs/components/footer"
    },
    {
      "name": "table",
      "description": "数据表格，支持斑马纹、边框、响应式滚动",
      "variants": ["default", "striped", "bordered"],
      "tags": ["display", "data", "layout"],
      "html_path": "/components/table/table.html",
      "demo_path": "/docs/components/table"
    },
    {
      "name": "tabs",
      "description": "标签切换组件，支持药丸/下划线样式，平滑切换动画",
      "variants": ["default", "pills", "underline"],
      "tags": ["navigation", "interactive", "layout"],
      "html_path": "/components/tabs/tabs.html",
      "demo_path": "/docs/components/tabs"
    },
    {
      "name": "alert",
      "description": "提示信息框，支持四种语义颜色和可关闭功能",
      "variants": ["info", "success", "warning", "danger"],
      "tags": ["display", "notification", "feedback"],
      "html_path": "/components/alert/alert.html",
      "demo_path": "/docs/components/alert"
    },
    {
      "name": "toast",
      "description": "通知弹窗，右上角浮出，支持成功/错误/加载状态",
      "variants": ["default", "success", "error", "loading"],
      "tags": ["notification", "overlay", "feedback"],
      "html_path": "/components/toast/toast.html",
      "demo_path": "/docs/components/toast"
    },
    {
      "name": "dropdown",
      "description": "下拉菜单，支持分组、分隔线、危险操作样式",
      "variants": ["default", "split"],
      "tags": ["navigation", "interactive", "menu"],
      "html_path": "/components/dropdown/dropdown.html",
      "demo_path": "/docs/components/dropdown"
    },
    {
      "name": "avatar",
      "description": "头像组件，支持图片/文字/图标，多种尺寸和状态指示器",
      "variants": ["default", "circle", "square"],
      "sizes": ["xs", "sm", "md", "lg", "xl"],
      "tags": ["display", "user", "media"],
      "html_path": "/components/avatar/avatar.html",
      "demo_path": "/docs/components/avatar"
    },
    {
      "name": "toggle",
      "description": "开关组件，纯 CSS 实现，支持标签和禁用状态",
      "variants": ["default", "labeled"],
      "tags": ["form", "interactive", "input"],
      "html_path": "/components/toggle/toggle.html",
      "demo_path": "/docs/components/toggle"
    },
    {
      "name": "progress",
      "description": "进度条，支持条纹/动画变体，确定和不确定状态",
      "variants": ["default", "striped", "animated"],
      "tags": ["display", "status", "feedback"],
      "html_path": "/components/progress/progress.html",
      "demo_path": "/docs/components/progress"
    },
    {
      "name": "accordion",
      "description": "折叠面板，纯 CSS details/summary 实现，平滑动画",
      "variants": ["default", "bordered"],
      "tags": ["layout", "content", "interactive"],
      "html_path": "/components/accordion/accordion.html",
      "demo_path": "/docs/components/accordion"
    },
    {
      "name": "breadcrumb",
      "description": "面包屑导航，支持箭头分隔符和图标",
      "variants": ["default", "arrow"],
      "tags": ["navigation", "layout"],
      "html_path": "/components/breadcrumb/breadcrumb.html",
      "demo_path": "/docs/components/breadcrumb"
    },
    {
      "name": "tooltip",
      "description": "工具提示，四个方向，纯 CSS hover 触发",
      "variants": ["top", "bottom", "left", "right"],
      "tags": ["display", "overlay", "feedback"],
      "html_path": "/components/tooltip/tooltip.html",
      "demo_path": "/docs/components/tooltip"
    },
    {
      "name": "glassmorphism",
      "description": "毛玻璃卡片，backdrop-filter 模糊 + 半透明背景 + 霓虹变体",
      "variants": ["default", "dark", "light", "neon"],
      "tags": ["visual", "card", "glass", "modern"],
      "css_path": "/components/glassmorphism/glassmorphism.css",
      "html_path": "/components/glassmorphism/glassmorphism.html",
      "demo_path": "/docs/components/glassmorphism"
    },
    {
      "name": "gradient-border",
      "description": "动画渐变边框，conic-gradient 旋转 + 彩虹/虚线变体",
      "variants": ["default", "slow", "fast", "rainbow", "dashed"],
      "tags": ["visual", "border", "animation", "modern"],
      "css_path": "/components/gradient-border/gradient-border.css",
      "html_path": "/components/gradient-border/gradient-border.html",
      "demo_path": "/docs/components/gradient-border"
    },
    {
      "name": "skeleton",
      "description": "骨架屏加载动画，shimmer 光效 + 预设形状(文本/头像/图片/卡片)",
      "variants": ["text", "title", "avatar", "image", "card", "dark", "pulse"],
      "tags": ["loading", "placeholder", "animation"],
      "css_path": "/components/skeleton/skeleton.css",
      "html_path": "/components/skeleton/skeleton.html",
      "demo_path": "/docs/components/skeleton"
    },
    {
      "name": "3d-tilt",
      "description": "3D 倾斜卡片，perspective + rotateX/Y + 光影变化",
      "variants": ["default", "gradient", "glass"],
      "tags": ["visual", "3d", "interactive", "modern"],
      "css_path": "/components/3d-tilt/3d-tilt.css",
      "html_path": "/components/3d-tilt/3d-tilt.html",
      "demo_path": "/docs/components/3d-tilt"
    },
    {
      "name": "aurora-bg",
      "description": "极光背景，多色光球漂移 + 模糊 + 网格叠加",
      "variants": ["default", "blue", "sunset"],
      "tags": ["visual", "background", "animation", "hero"],
      "css_path": "/components/aurora-bg/aurora-bg.css",
      "html_path": "/components/aurora-bg/aurora-bg.html",
      "demo_path": "/docs/components/aurora-bg"
    },
    {
      "name": "magnetic-btn",
      "description": "磁性按钮，悬停放大发光 + 描边/幽灵/发光变体 + JS 磁性跟随",
      "variants": ["default", "outline", "ghost", "glow"],
      "tags": ["button", "interactive", "animation", "cta"],
      "css_path": "/components/magnetic-btn/magnetic-btn.css",
      "html_path": "/components/magnetic-btn/magnetic-btn.html",
      "demo_path": "/docs/components/magnetic-btn"
    }
  ],
  "patterns": [
    {
      "name": "landing-page",
      "description": "完整落地页布局：Hero + Features + CTA",
      "components_used": ["hero", "card", "button"],
      "demo_path": "/docs/patterns/landing"
    },
    {
      "name": "dashboard",
      "description": "管理后台布局：Navbar + Sidebar + Table + Card",
      "components_used": ["navbar", "table", "card", "button"],
      "demo_path": "/docs/patterns/dashboard"
    },
    {
      "name": "form-page",
      "description": "表单页面：Input + Toggle + Button + Alert",
      "components_used": ["input", "toggle", "button", "alert"],
      "demo_path": "/docs/patterns/form"
    }
  ],
  "ai_usage": {
    "instruction": "在创建 UI 时，先读取此 manifest 了解可用组件。优先使用已有的组件和 tokens，不要凭空生成样式。组件代码可从 html_path 获取，直接复制粘贴即可使用。",
    "token_import": "在 HTML 头部引入 <link rel='stylesheet' href='http://101.37.166.208:11930/tokens/tokens.css'>",
    "component_usage": "每个组件是纯 HTML+CSS，复制 src/components/<name>/<name>.html 即可使用"
  }
}
