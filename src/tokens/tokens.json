{
  "$schema": "https://your-lib.vercel.app/tokens-schema.json",
  "version": "0.1.0",
  "color": {
    "primary": "#6366f1",
    "primary-light": "#818cf8",
    "primary-dark": "#4f46e5",
    "primary-ghost": "rgba(99, 102, 241, 0.08)",
    "secondary": "#06b6d4",
    "secondary-light": "#22d3ee",
    "secondary-dark": "#0891b2",
    "success": "#10b981",
    "warning": "#f59e0b",
    "danger": "#ef4444",
    "info": "#3b82f6",
    "bg": "#ffffff",
    "bg-subtle": "#f8fafc",
    "bg-muted": "#f1f5f9",
    "surface": "#ffffff",
    "border": "#e2e8f0",
    "text": "#0f172a",
    "text-secondary": "#475569",
    "text-muted": "#94a3b8",
    "text-inverse": "#ffffff"
  },
  "font": {
    "sans": "Inter, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif",
    "mono": "JetBrains Mono, 'Fira Code', 'SF Mono', monospace",
    "display": "Inter"
  },
  "text": {
    "xs": "0.75rem",
    "sm": "0.875rem",
    "base": "1rem",
    "lg": "1.125rem",
    "xl": "1.25rem",
    "2xl": "1.5rem",
    "3xl": "1.875rem",
    "4xl": "2.25rem",
    "5xl": "3rem",
    "6xl": "3.75rem"
  },
  "space": {
    "1": "0.25rem",
    "2": "0.5rem",
    "3": "0.75rem",
    "4": "1rem",
    "5": "1.25rem",
    "6": "1.5rem",
    "8": "2rem",
    "10": "2.5rem",
    "12": "3rem",
    "16": "4rem",
    "20": "5rem",
    "24": "6rem"
  },
  "radius": {
    "sm": "6px",
    "md": "10px",
    "lg": "16px",
    "xl": "24px",
    "full": "9999px"
  },
  "shadow": {
    "sm": "0 1px 2px rgba(0,0,0,0.05)",
    "md": "0 4px 6px -1px rgba(0,0,0,0.07)",
    "lg": "0 10px 15px -3px rgba(0,0,0,0.08)",
    "xl": "0 20px 25px -5px rgba(0,0,0,0.08)"
  },
  "transition": {
    "fast": "150ms",
    "normal": "250ms",
    "slow": "400ms",
    "ease": "cubic-bezier(0.4, 0, 0.2, 1)",
    "spring": "cubic-bezier(0.34, 1.56, 0.64, 1)"
  }
}
